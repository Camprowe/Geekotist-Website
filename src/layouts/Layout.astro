---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="google-adsense-account" content="ca-pub-5252068481252472">
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:site_name" content="Geekotist by Camprowe" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />

		<!-- Preconnect Links -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />
		<!-- {movieSchema && (
			<script type="application/ld+json" set:html={JSON.stringify(movieSchema)} />
		)} -->
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #ffffff;
		--text-color: #1c1c1c;
		--text-muted: #1c1c1c;
		--accent-color: #005AFF; /* Secondary Camprowe Primary */
	}

	*, *::before, *::after {
		box-sizing: border-box;
	}

	html {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100vh;
		background-color: #ffffff; /* Cinematic dark ambient frame background for extra-wide displays */
	}

	body {
		margin: 0 auto;
		padding: 0;
		width: 100%;
		max-width: 1440px;
		min-height: 100vh;
		background-color: var(--bg-color);
		color: var(--text-color);
		font-family: 'Inter', sans-serif;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
		overflow-x: hidden;
		position: relative;
	}
	
	a {
		color: inherit;
		text-decoration: none;
	}
</style>
