---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import MovieGrid from '../components/MovieGrid.astro';
import Footer from '../components/Footer.astro';
import movies from '../data/movies.json';
import { slugify } from '../utils/slugify.js';

// Get unique categories
const categories = [...new Set(movies.map(m => m.category))];
---

<Layout 
	title="Geekotist by Camprowe - Everything you need to know about your favourite Games, Movies and TV Shows" 
	description="Geekotist is a Camprowe Production about the worlds you can't stop thinking about, the who, what, where, and when behind your favourite games, film, and TV."
>
	<Header />
	<main>
		<Hero />
		{categories.map(category => {
			const categoryMovies = movies.filter(m => m.category === category).slice(0, 4); // Show top 4
			const categorySlug = slugify(category);
			return (
				<MovieGrid 
					title={`${category}s`} 
					movies={categoryMovies} 
					categoryLink={`/category/${categorySlug}`} 
				/>
			);
		})}
	</main>
	<Footer />
</Layout>
