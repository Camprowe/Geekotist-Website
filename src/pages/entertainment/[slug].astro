---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import MovieGrid from '../../components/MovieGrid.astro';
import KnowledgeGrid from '../../components/KnowledgeGrid.astro';
import movies from '../../data/movies.json';
import knowledge from '../../data/knowledge.json';
import { slugify } from '../../utils/slugify.js';

export function getStaticPaths() {
	return movies.map(movie => ({
		params: { slug: slugify(movie.title) },
		props: { movie }
	}));
}

const { movie } = Astro.props;

// Filter related movies by category/genre
let relatedMovies = movies.filter(m => m.category === movie.category && m.title !== movie.title);

let relatedFacts = knowledge.filter(k => k.entertainment.includes(movie.title));

// Fallback logic to make sure we always have 4 movies
if (relatedMovies.length < 4) {
	const otherMovies = movies
		.filter(m => m.title !== movie.title && !relatedMovies.some(r => r.title === m.title))
		.sort((a, b) => parseFloat(b.rating) - parseFloat(a.rating));
	
	relatedMovies = [...relatedMovies, ...otherMovies].slice(0, 4);
} else {
	relatedMovies = relatedMovies.slice(0, 4);
}
---

<Layout 
	title={`${movie.title} (${movie.year}) - Geekotist by Camprowe`}
	description={`Discover all Geekotist content about ${movie.title} produced by Camprowe, including general details about the ${movie.category}.`}
	image={movie.imageUrl}
	type="video.movie"
	movieData={movie}
>
	<Header />
	<main class="movie-page">
		<div class="backdrop">
			<img 
				src={movie.imageUrl} 
				alt={`${movie.title} Backdrop`} 
				fetchpriority="high" 
				loading="eager" 
				onload="this.classList.add('loaded'); this.parentElement.classList.add('loaded');" 
			/>
			<div class="overlay"></div>
		</div>
		<div class="content">
			<div class="poster-col">
				<img 
					src={movie.imageUrl} 
					alt={movie.title} 
					class="main-poster" 
					fetchpriority="high" 
					loading="eager" 
					onload="this.classList.add('loaded'); this.parentElement.classList.add('loaded');" 
				/>
			</div>
			<div class="info-col">
				<span class="category-badge">{movie.category}</span>
				<h1 class="title">{movie.title}</h1>
				<div class="meta">
					<span class="year">{movie.year}</span>
					<span class="dot">&bull;</span>
					<span class="rating">
						{movie.producer}
					</span>
				</div>
				<h3 class="overview-title">Overview</h3>
				<p class="description">{movie.description}</p>
			</div>
		</div>

		{relatedFacts.length > 0 && (
			<div class="related-section">
				<KnowledgeGrid title={"Details from " + movie.title} knowledge={relatedFacts} />
			</div>
		)}

		{relatedMovies.length > 0 && (
			<div class="related-section">
				<MovieGrid title={"More " + movie.category + "s"} movies={relatedMovies} />
			</div>
		)}

	</main>
	<Footer />
</Layout>

<style>
	.movie-page {
		position: relative;
		min-height: 100vh;
	}

	.backdrop {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 70vh;
		z-index: -1;
		background-color: #050505;
		background-image: linear-gradient(
			90deg,
			rgba(255, 255, 255, 0.01) 25%,
			rgba(255, 255, 255, 0.04) 50%,
			rgba(255, 255, 255, 0.01) 75%
		);
		background-size: 200% 100%;
		animation: loading-pulse 2s infinite;
	}

	.backdrop.loaded {
		animation: none;
		background: none;
	}

	.backdrop img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: center 20%;
		filter: blur(5px);
		opacity: 0;
		transition: opacity 0.6s ease-in-out;
	}

	.backdrop img.loaded {
		opacity: 0.4;
	}

	.overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(to top, var(--bg-color) 0%, transparent 100%);
	}

	.content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 10rem 5% 5rem 5%;
		display: flex;
		gap: 4rem;
		position: relative;
		z-index: 10;
	}

	.poster-col {
		flex: 0 0 300px;
		aspect-ratio: 2 / 3;
		border-radius: 12px;
		overflow: hidden;
		background-size: 100% 100%;
		animation: loading-pulse 1.5s infinite;
	}

	.poster-col.loaded {
		animation: none;
		background: none;
	}

	.main-poster {
		width: 100%;
		height: 100%;
		object-fit: contain;
		border-radius: 12px;
		opacity: 0;
		transition: opacity 0.5s ease-in-out;
	}

	.main-poster.loaded {
		opacity: 1;
	}

	@keyframes loading-pulse {
		0% {
			background-position: 200% 0;
		}
		100% {
			background-position: -200% 0;
		}
	}

	.info-col {
		flex: 1;
		padding-top: 2rem;
	}

	.category-badge {
		background-color: var(--accent-color);
		color: white;
		padding: 0.4rem 1rem;
		border-radius: 4px;
		font-size: 0.9rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 1px;
		display: inline-block;
		margin-bottom: 1.5rem;
	}

	.title {
		font-size: 3.5rem;
		font-weight: 800;
		margin: 0 0 1rem 0;
		line-height: 1.1;
		letter-spacing: -1px;
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-size: 1.2rem;
		color: var(--text-muted);
		margin-bottom: 3rem;
	}

	.dot {
		color: #555;
	}

	.rating {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: #ffffff;
		font-weight: 600;
	}

	.overview-title {
		font-size: 1.5rem;
		font-weight: 600;
		margin: 0 0 1rem 0;
	}

	.description {
		font-size: 1.1rem;
		line-height: 1.8;
		margin-bottom: 3rem;
		max-width: 800px;
	}

	.btn {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 1rem 2rem;
		border: none;
		border-radius: 4px;
		font-size: 1.1rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.3s ease;
	}

	.btn-primary {
		background-color: var(--text-color);
		color: var(--bg-color);
		text-shadow: none;
	}

	.btn-primary:hover {
		background-color: rgba(255, 255, 255, 0.8);
		transform: scale(1.05);
	}

	@media (max-width: 900px) {
		.content {
			flex-direction: column;
			align-items: center;
			text-align: center;
			padding-top: 8rem;
		}

		.meta {
			justify-content: center;
		}
	}

	.related-section {
		max-width: 1200px;
		margin: 0 auto;
		padding: 3rem 5% 5rem 5%;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}
</style>
