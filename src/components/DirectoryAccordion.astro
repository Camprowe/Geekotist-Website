---
import movies from '../data/movies.json';
import { slugify } from '../utils/slugify.js';

// 1. Group by Category
const categories = [...new Set(movies.map(m => m.category))].sort();
const moviesByCategory = categories.map(category => {
	return {
		category,
		movies: movies.filter(m => m.category === category)
	};
});

// 2. Group by Year
const years = [...new Set(movies.map(m => m.year))].sort((a, b) => parseInt(b) - parseInt(a)); // Sort descending
const moviesByYear = years.map(year => {
	return {
		year,
		movies: movies.filter(m => m.year === year)
	};
});
---

<section class="directory-section">
	<div class="directory-container">
		<h2>Browse Directory</h2>
		
		<div class="accordion">
			<!-- Categories -->
			{moviesByCategory.map(group => (
				<details class="accordion-item">
					<summary class="accordion-header">
						{group.category} Movies
						<span class="count">{group.movies.length}</span>
					</summary>
					<div class="accordion-content">
						<ul>
							{group.movies.map(movie => (
								<li>
									<a href={`/movie/${slugify(movie.title)}`}>
										{movie.title} <span class="year-label">({movie.year})</span>
									</a>
								</li>
							))}
						</ul>
					</div>
				</details>
			))}

			<!-- Years -->
			<details class="accordion-item years-parent">
				<summary class="accordion-header special-header">
					Browse by Year
					<span class="count">{years.length}</span>
				</summary>
				<div class="accordion-content">
					{moviesByYear.map(group => (
						<details class="accordion-item nested-item">
							<summary class="accordion-header nested-header">
								{group.year}
								<span class="count">{group.movies.length}</span>
							</summary>
							<div class="accordion-content nested-content">
								<ul>
									{group.movies.map(movie => (
										<li>
											<a href={`/movie/${slugify(movie.title)}`}>
												{movie.title} <span class="cat-label">[{movie.category}]</span>
											</a>
										</li>
									))}
								</ul>
							</div>
						</details>
					))}
				</div>
			</details>
		</div>
	</div>
</section>

<style>
	.directory-section {
		padding: 3rem 5%;
		background-color: var(--bg-color);
		padding-top: 0;
	}

	.directory-container {
		max-width: 1200px;
		margin: 0 auto;
	}

	h2 {
		font-size: 1.8rem;
		font-weight: 800;
		margin-bottom: 1.5rem;
		letter-spacing: -0.5px;
	}

	.accordion {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1rem;
		align-items: start;
	}

	.accordion-item {
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 8px;
		overflow: hidden;
		background-color: #111111;
		transition: border-color 0.3s ease;
	}

	.accordion-item:hover {
		border-color: rgba(255, 255, 255, 0.2);
	}

	.accordion-header {
		padding: 1rem 1.2rem;
		font-size: 1.05rem;
		font-weight: 600;
		background-color: #111111;
		cursor: pointer;
		display: flex;
		justify-content: space-between;
		align-items: center;
		transition: background-color 0.3s ease;
		list-style: none;
	}

	/* Custom arrow */
	.accordion-header::-webkit-details-marker {
		display: none;
	}

	.accordion-header::after {
		content: '▼';
		font-size: 0.7rem;
		color: #666;
		transition: transform 0.3s ease;
	}

	details[open] > .accordion-header::after {
		transform: rotate(180deg);
		color: var(--text-color);
	}

	.accordion-header:hover {
		background-color: #161616;
	}

	.special-header {
		background-color: #151515;
		border: 1px solid rgba(229, 9, 20, 0.2);
		border-radius: 8px;
	}
	
	details[open] > .special-header {
		border-bottom-left-radius: 0;
		border-bottom-right-radius: 0;
	}

	.years-parent {
		grid-column: 1 / -1; /* spans full width on desktop */
	}

	.count {
		font-size: 0.8rem;
		background: rgba(255, 255, 255, 0.08);
		padding: 0.15rem 0.5rem;
		border-radius: 10px;
		color: #888;
		margin-left: auto;
		margin-right: 0.8rem;
	}

	.accordion-content {
		padding: 0.8rem 1.2rem;
		background-color: #080808;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
	}

	ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	li {
		margin-bottom: 0.5rem;
	}
	
	li:last-child {
		margin-bottom: 0;
	}

	a {
		color: #aaaaaa;
		text-decoration: none;
		transition: color 0.2s ease;
		display: inline-block;
		width: 100%;
		padding: 0.2rem 0;
		font-size: 0.95rem;
	}

	a:hover {
		color: #ffffff;
	}

	.year-label, .cat-label {
		color: #555555;
		font-size: 0.85rem;
		margin-left: 0.4rem;
	}

	/* Nested Accordion Styles */
	.nested-item {
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 6px;
		margin-bottom: 0.5rem;
	}
	
	.nested-item:last-child {
		margin-bottom: 0;
	}

	.nested-header {
		padding: 0.8rem 1rem;
		font-size: 0.95rem;
		background-color: #121212;
	}

	.nested-content {
		padding: 0.8rem 1rem;
		background-color: #040404;
	}

	@media (max-width: 768px) {
		.directory-section {
			padding: 2rem 5%;
		}
		
		.accordion {
			grid-template-columns: 1fr;
		}

		.years-parent {
			grid-column: span 1;
		}
	}
</style>
