---
interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
	type?: string;
	movieData?: {
		title: string;
		description: string;
		imageUrl: string;
		year: string;
		rating: string;
		category: string;
	};
}

const {
	title = "Geekotist by Camprowe - Everything you need to know about your favourite Games, Movies and TV Shows",
	description = "Geekotist is a Camprowe Production about the worlds you can't stop thinking about, the who, what, where, and when behind your favourite games, film, and TV.",
	image = "https://geekotist.com/logo.png", // Default featured movie backdrop
	canonicalURL = Astro.url.href,
	type = "website",
	movieData
} = Astro.props;

// Structured Data (JSON-LD)
const baseSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "Geekotist by Camprowe",
	"url": "https://geekotist.com",
	"author": {
    "@type": "Organization",
		"name": "Camprowe",
		"url": "https://camprowe.com",
		"logo": "https://camprowe.com/logo.png",
		"sameAs": [
			"https://youtube.com/@TheCamprowe",
			"https://x.com/TheCamprowe",
			"https://linkedin.com/company/Camprowe",
			"https://instagram.com/thecamprowe",
			"https://tiktok.com/@camprowe"
		]
	},
	"potentialAction": {
		"@type": "SearchAction",
		"target": "https://geekotist.com/?search={search_term_string}",
		"query-input": "required name=search_term_string"
	}
};

