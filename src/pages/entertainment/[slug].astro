---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import MovieGrid from '../../components/MovieGrid.astro';
import KnowledgeGrid from '../../components/KnowledgeGrid.astro';
import movies from '../../data/movies.json';
import knowledge from '../../data/knowledge.json';
import { slugify } from '../../utils/slugify.js';

export function getStaticPaths() {
	return movies.map(movie => ({
		params: { slug: slugify(movie.title) },
		props: { movie }
	}));
}

const { movie } = Astro.props;

// Filter related movies by category/genre
let unshuffledEntertainment = movies.filter(m => m.category === movie.category && m.title !== movie.title);

let relatedEntertainment = [...unshuffledEntertainment].sort(() => Math.random() - 0.5).slice(0,4);

let unshuffledKnowledge = knowledge.filter(k => k.entertainment.includes(movie.title));

let relatedKnowledge = [...unshuffledKnowledge].sort(() => Math.random() - 0.5).slice(0,4);

---

<Layout 
	title={`${movie.title} (${movie.year}) - Geekotist by Camprowe`}
	description={`Discover all Geekotist content about ${movie.title} produced by Camprowe, including general details about the ${movie.category}.`}
	image={movie.imageUrl}
	type="video.movie"
	movieData={movie}
>
	<Header />
	<main class="movie-page">
		<section class="hero">
			<div class="hero-inner">
		
			<div class="art">
			</div>
		
			<div class="content">
		
				<h1 class="title">{movie.title}</h1>

				<div class="tags">
					<span class="tag">{movie.category}</span>
				</div>
		
				<div class="meta-grid">
				<div>
					<span class="meta-label">STUDIO</span>
					<span class="meta-value">{movie.producer}</span>
				</div>
				<div>
					<span class="meta-label">RELEASED</span>
					<span class="meta-value">{movie.year}</span>
				</div>
				</div>
		
				<p class="desc">{movie.description}</p>
		
				<!-- <div class="actions">
					<a class="btn btn-primary" href="#">
						Watch the Video Essay
						<svg viewBox="0 0 12 12" fill="none"><path d="M1 0.5L11 6L1 11.5V0.5Z" fill="currentColor"/></svg>
					</a>
					<a class="btn btn-secondary" href="#">
						All Episodes on This Game
					</a>
				</div> -->
			</div>
		
			</div>
		</section>

		{relatedKnowledge.length > 0 && (
			<div class="related-section">
				<KnowledgeGrid title={"Knowledge from " + movie.title} knowledge={relatedKnowledge} knowledgeLink={`/entertainment/${slugify(movie.title)}/knowledge`}  />
			</div>
		)}

		{relatedEntertainment.length > 0 && (
			<div class="related-section">
				<MovieGrid title={"More " + movie.category + "s"} movies={relatedEntertainment} />
			</div>
		)}

	</main>
	<Footer />
</Layout>

<style define:vars={{image: `url("${movie.imageUrl}")`}}>
  
	.movie-page {
		margin: 0 auto;
		padding-top: 8rem;
		min-height: 100vh;
	}	

	/* ---------- hero shell ---------- */
  .hero{
    position: relative;
    padding: 64px 32px;
    overflow: hidden;
  }
 
  .hero-inner{
    margin: 0 auto;
    display: grid;
    grid-template-columns: 35% 60%;
    gap: 5%;
    align-items: center;
  }
 
  /* ---------- 1:1 image ---------- */
  .art{
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 6px;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(232,180,88,0.16), transparent 60%),
      linear-gradient(180deg, #24262A 0%, #1A1B1D 100%);
	background-image: var(--image);
	background-size: cover;
    border: 1px solid var(--hairline);
    box-shadow: 0 24px 48px -20px rgba(0,0,0,0.6);
  }
 
  /* ---------- content ---------- */
  .content{ min-width: 0; }
 
  .title{
    font-weight: 900;
    font-size: 2.5em;
    line-height: 1.15;
    color: #000000;
    margin: 0 0 12px;
  }
 
  .tags{
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 22px;
  }
 
  .tag{
    font-size: 0.75em;
    letter-spacing: 0.1em;
    color: #ffffff;
    background: #1c1c1c;
    border: 1px solid var(--hairline);
    padding: 5px 10px;
    border-radius: 5px;
  }
 
  .meta-grid{
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 18px 32px;
    padding: 18px 0;
    margin-bottom: 22px;
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
 
  .meta-label{
    font-size: 0.75em;
    letter-spacing: 0.05em;
    color: #FFA500;
    display: block;
    margin-bottom: 5px;
  }
 
  .meta-value{
    font-size: 1em;
    color: #1c1c1c;
  }
 
  .desc{
    font-size: 1.2em;
    line-height: 1.5;
    color: #1c1c1c;
    margin: 0 0 28px;
  }
 
  .actions{
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
 
  .btn{
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 13px;
    text-decoration: none;
    padding: 11px 18px;
    border-radius: 4px;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
 
  .btn:focus-visible{ outline: 2px solid var(--brass); outline-offset: 2px; }
  .btn:hover{ transform: translateY(-1px); }
 
  .btn-primary{
    background: var(--ember);
    color: var(--paper);
  }
  .btn-primary:hover{ background: var(--ember-hover); }
 
  .btn-secondary{
    background: transparent;
    color: var(--paper);
    border: 1px solid var(--hairline);
  }
  .btn-secondary:hover{ border-color: var(--brass); }
 
  .btn svg{ width: 12px; height: 12px; }
 
  /* ---------- responsive ---------- */
  @media (max-width: 1100px){
    .hero{ padding: 40px 20px; }
    .hero-inner{
      grid-template-columns: 100%;
    }
    .art{ max-width: 100%; }
    .title{ font-size: 5em; }
    .meta-grid{ grid-template-columns: repeat(2, auto); }
  }
  
	.related-section {
		margin: 0 auto;
		padding: 2rem 0;
		border-top: 1px solid #1c1c1c;
	}
</style>
