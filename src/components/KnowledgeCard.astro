---
interface Props {
  title: string;
	description: string;
  image: string;
  source: string
}

const { title, description, image, source } = Astro.props;
---

<article class="card-main">			
  <div class="card">
 
    <div class="thumb is-placeholder">
    </div>
 
    <div class="body">
      <div class="eyebrow">
        <span class="fact-index">KNOWLEDGE</span>
        <span class="fact-index"><a href={source}>Source</a></span>
      </div>
 
      <h2 class="headline">{title}</h2>
      <p class="desc">{description}</p>
    </div>
 
  </div>
</article>

<style define:vars={{image: `url("${image}")`}}>
 
  *{ box-sizing: border-box; }

  .card-main {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

.card{
    width: 100%;
    height: 100%;
    background: #1c1c1c;
    border-radius: 6px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(237,230,216,0.06) inset,
      0 30px 60px -20px rgba(0,0,0,0.6);
  }
 
  /* ---------- image / thumbnail slot ---------- */
  .thumb{
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(232,180,88,0.16), transparent 60%),
      linear-gradient(180deg, #24262A 0%, #1A1B1D 100%);
    background-image: var(--image);
	  background-size: cover;
    border-bottom: 2px solid #ffffff;
  }
  
 
  /* ---------- body ---------- */
  .body{
    padding: 22px 24px 24px;
  }
 
  .eyebrow{
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
 
  .fact-index{
    font-size: 0.75em;
    color: #ffffff;
    letter-spacing: 0.05em;
  }
 
  .headline{
    font-weight: 600;
    font-size: 1.25em;
    line-height: 1.3;
    color: #ffffff;
    margin: 0 0 10px;
  }
 
  .desc{
    font-size: 1em;
    line-height: 1.65;
    color: #ffffff;
  }
</style>
