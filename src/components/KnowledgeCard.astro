---
interface Props {
  title: string;
	description: string;
  image: string;
  source: string
}

const { title, description, image, source } = Astro.props;
---

<article>			
  <div class="card">
 
    <div class="thumb is-placeholder">
    </div>
 
    <div class="body">
      <div class="eyebrow">
        <span class="fact-index">LORE &amp; CRAFT</span>
        <span class="fact-index"><a href="{source}">Source</a></span>
      </div>
 
      <h2 class="headline">{title}</h2>
      <p class="desc">{description}</p>
    </div>
 
  </div>				
	<!-- <div class="window" tabindex="0">
		<div class="window__title-bar">
			<div class="window__title">
			{title}
			</div>
			<div class="buttons">
				<span class="window__btn">
					&#150;
				</span>
				<span class="window__btn">
					&#9744;
				</span>
				<span class="window__btn">
					&#88;
				</span>
			</div>
		</div>

		<div class="window__body">
			<img src={image} />
			<p>{description} (<a href={source}>Source</a>)</p>
		</div>
	</div> -->
</article>

<style define:vars={{image: `url("${image}")`}}>
:root{
    --ink: #17181A;
    --ink-raised: #1D1F21;
    --paper: #EDE6D8;
    --brass: #FFA500;
    --spotlight: #E8B458;
    --moss: #6C7A5E;
    --hairline: rgba(237,230,216,0.10);
  }
 
  *{ box-sizing: border-box; }

  article{
    margin: 0;
    min-height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

.card{
    width: 100%;
    height: 100%;
    background: var(--ink);
    border-radius: 6px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(237,230,216,0.06) inset,
      0 30px 60px -20px rgba(0,0,0,0.6);
  }
 
  /* ---------- image / thumbnail slot ---------- */
  .thumb{
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(232,180,88,0.16), transparent 60%),
      linear-gradient(180deg, #24262A 0%, #1A1B1D 100%);
    background-image: var(--image);
	  background-size: cover;
    border-bottom: 1px solid var(--hairline);
  }
  
 
  /* ---------- body ---------- */
  .body{
    padding: 22px 24px 24px;
  }
 
  .eyebrow{
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
 
  .fact-index{
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--paper-dim);
    letter-spacing: 0.05em;
  }
 
  .headline{
    font-family: 'Roboto Slab', serif;
    font-weight: 600;
    font-size: 19px;
    line-height: 1.3;
    color: var(--paper);
    margin: 0 0 10px;
  }
 
  .desc{
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--paper);
    margin: 0 0 20px;
  }
 
  .footer{
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    border-top: 1px solid var(--hairline);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10.5px;
    color: var(--moss);
    letter-spacing: 0.04em;
  }
 
  .footer .from{
    color: rgba(237,230,216,0.35);
  }

