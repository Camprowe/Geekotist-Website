---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
	title="Legal Center & Policies - SR Studio Antigravity Movies" 
	description="Review the legal guidelines, terms of service, cookie operational frameworks, and privacy protection protocols at SR Studio."
>
	<Header />
	
	<main class="policy-container">
		<!-- Hero Section -->
		<section class="policy-hero">
			<div class="hero-glow"></div>
			<h1>Legal <span>Center</span></h1>
			<p>Last updated: May 18, 2026. Please read our operational guidelines and policies below.</p>
		</section>

		<!-- Interactive Tab Layout -->
		<div class="policy-layout">
			<!-- Sidebar navigation -->
			<aside class="policy-sidebar glassmorphic">
				<button class="tab-btn active" data-tab="privacy">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
						<path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
					</svg>
					<span>Privacy Policy</span>
				</button>
				<button class="tab-btn" data-tab="terms">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
						<polyline points="14 2 14 8 20 8"></polyline>
						<line x1="16" y1="13" x2="8" y2="13"></line>
						<line x1="16" y1="17" x2="8" y2="17"></line>
						<polyline points="10 9 9 9 8 9"></polyline>
					</svg>
					<span>Terms of Service</span>
				</button>
				<button class="tab-btn" data-tab="cookies">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10"></circle>
						<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
					</svg>
					<span>Cookie Policy</span>
				</button>
			</aside>

			<!-- Document Content Area -->
			<section class="policy-content glassmorphic">
				<!-- Privacy Policy Panel -->
				<div class="tab-panel active" id="privacy">
					<h2>Privacy Policy</h2>
					<p class="panel-lead">Your privacy is fundamental to our core values. This policy explains how we collect, safeguard, and use your data when visiting AGMovies.</p>
					
					<div class="policy-clause">
						<h3>1. Information We Collect</h3>
						<p>We do not require account registration to browse our directory. We only collect telemetry data to analyze site performance. This includes:</p>
						<ul>
							<li>Operating system and device types used.</li>
							<li>Standard browser identifiers and basic interactions.</li>
							<li>Anonymized geographic coordinates based on IP addresses.</li>
						</ul>
					</div>

					<div class="policy-clause">
						<h3>2. How We Use Information</h3>
						<p>All data collected is utilized exclusively to maintain site stability, speed up content caching, improve general recommendations, and debug client-side interface scripts.</p>
					</div>

					<div class="policy-clause">
						<h3>3. Security Safeguards</h3>
						<p>We implement advanced TLS encryptions across all networks and regularly audit our server hosts to ensure unauthorized entities cannot intercept our database queries.</p>
					</div>
				</div>

				<!-- Terms of Service Panel -->
				<div class="tab-panel" id="terms">
					<h2>Terms of Service</h2>
					<p class="panel-lead">Please review the rules and codes of conduct regarding your usage of the AGMovies service directory.</p>
					
					<div class="policy-clause">
						<h3>1. Acceptable Use</h3>
						<p>You agree to use AGMovies solely for personal, non-commercial discovery of movie information. Any automated scraping, crawling, or DDOS requests aimed at our servers are strictly prohibited.</p>
					</div>

					<div class="policy-clause">
						<h3>2. Intellectual Property</h3>
						<p>All content layout, custom graphics, metadata algorithms, CSS styles, and animations are property of AGMovies. Movie poster images and summaries are used under Fair Use guidelines for educational and cataloging purposes.</p>
					</div>

					<div class="policy-clause">
						<h3>3. Limitation of Liability</h3>
						<p>AGMovies is provided "as is" without warranties of any kind. We are not liable for any server interruptions, omissions in dataset records, or external links leading outside our domain.</p>
					</div>
				</div>

				<!-- Cookie Policy Panel -->
				<div class="tab-panel" id="cookies">
					<h2>Cookie Policy</h2>
					<p class="panel-lead">Learn more about how and why we utilize cookies on our system to deliver a smooth navigation experience.</p>
					
					<div class="policy-clause">
						<h3>1. What Are Cookies?</h3>
						<p>Cookies are small files stored directly on your computer's hard drive by your web browser. They help websites remember preferences and details about your past visits.</p>
					</div>

					<div class="policy-clause">
						<h3>2. Our Cookie Implementations</h3>
						<p>We utilize cookies to store persistent display filters (e.g. accordion states or theme selections) so you don't have to reconfigure them each time you load the homepage.</p>
					</div>

					<div class="policy-clause">
						<h3>3. Disabling Cookies</h3>
						<p>You can adjust your browser configurations to decline all cookies or to alert you when a cookie is placed. Note that doing so may reset certain layout preferences upon page refreshes.</p>
					</div>
				</div>
			</section>
		</div>
	</main>

	<Footer />
</Layout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const tabButtons = document.querySelectorAll('.tab-btn');
		const tabPanels = document.querySelectorAll('.tab-panel');

		tabButtons.forEach(button => {
			button.addEventListener('click', () => {
				// Remove active class from all buttons and panels
				tabButtons.forEach(btn => btn.classList.remove('active'));
				tabPanels.forEach(panel => {
					panel.classList.remove('active');
					panel.classList.remove('fade-in');
				});

				// Add active class to clicked button
				button.classList.add('active');

				// Target active panel
				const tabId = button.getAttribute('data-tab');
				const targetPanel = document.getElementById(tabId);
				
				if (targetPanel) {
					targetPanel.classList.add('active');
					// Trigger CSS fade animation
					setTimeout(() => {
						targetPanel.classList.add('fade-in');
					}, 20);
				}
			});
		});
	});
</script>

<style>
	.policy-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 8rem 5% 6rem 5%;
		font-family: 'Inter', sans-serif;
	}

	/* Hero section styling */
	.policy-hero {
		position: relative;
		text-align: center;
		padding: 3rem 0 4rem 0;
	}

	.hero-glow {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 350px;
		height: 350px;
		background: radial-gradient(circle, rgba(229, 9, 20, 0.12) 0%, rgba(0,0,0,0) 75%);
		z-index: 1;
		pointer-events: none;
	}

	.policy-hero h1 {
		font-size: 3.5rem;
		font-weight: 800;
		margin: 0 0 1rem 0;
		letter-spacing: -1.5px;
	}

	.policy-hero h1 span {
		color: var(--accent-color);
	}

	.policy-hero p {
		font-size: 1.15rem;
		color: #aaaaaa;
		max-width: 600px;
		margin: 0 auto;
		line-height: 1.6;
	}

	/* Sidebar & content grid layout */
	.policy-layout {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
		align-items: start;
	}

	@media (min-width: 768px) {
		.policy-layout {
			grid-template-columns: 250px 1fr;
		}
	}

	/* Common glassmorphic design system */
	.glassmorphic {
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 12px;
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}

	/* Sidebar buttons panel */
	.policy-sidebar {
		padding: 1.5rem;
		display: flex;
		flex-direction: row;
		gap: 0.8rem;
		overflow-x: auto;
		scrollbar-width: none; /* Hide scrollbar for clean visual */
	}

	.policy-sidebar::-webkit-scrollbar {
		display: none;
	}

	@media (min-width: 768px) {
		.policy-sidebar {
			flex-direction: column;
			overflow-x: visible;
		}
	}

	.tab-btn {
		background: none;
		border: none;
		outline: none;
		color: #888888;
		padding: 1rem 1.2rem;
		border-radius: 6px;
		cursor: pointer;
		font-family: inherit;
		font-size: 0.95rem;
		font-weight: 600;
		display: flex;
		align-items: center;
		gap: 0.8rem;
		transition: all 0.3s ease;
		white-space: nowrap;
		flex-shrink: 0;
		border-left: 2px solid transparent;
	}

	.tab-btn:hover {
		color: white;
		background: rgba(255, 255, 255, 0.03);
	}

	.tab-btn.active {
		color: white;
		background: rgba(229, 9, 20, 0.08);
		border-left-color: var(--accent-color);
	}

	@media (max-width: 767px) {
		.tab-btn {
			border-left: none;
			border-bottom: 2px solid transparent;
		}
		
		.tab-btn.active {
			border-bottom-color: var(--accent-color);
		}
	}

	/* Document contents panel */
	.policy-content {
		padding: 3rem 2.5rem;
		min-height: 450px;
	}

	/* Tab panel animations */
	.tab-panel {
		display: none;
		opacity: 0;
		transform: translateY(10px);
		transition: opacity 0.35s ease, transform 0.35s ease;
	}

	.tab-panel.active {
		display: block;
		opacity: 1;
		transform: translateY(0);
	}

	/* Optional JS trigger helper */
	.tab-panel.fade-in {
		opacity: 1;
		transform: translateY(0);
	}

	.tab-panel h2 {
		font-size: 2rem;
		font-weight: 800;
		margin: 0 0 1rem 0;
	}

	.panel-lead {
		font-size: 1.1rem;
		line-height: 1.6;
		color: #cccccc;
		margin-bottom: 2.5rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		padding-bottom: 1.5rem;
	}

	.policy-clause {
		margin-bottom: 2.5rem;
		border-left: 2px solid transparent;
		padding-left: 0;
		transition: all 0.3s ease;
	}

	.policy-clause:hover {
		border-left-color: var(--accent-color);
		padding-left: 1rem;
	}

	.policy-clause h3 {
		font-size: 1.25rem;
		font-weight: 600;
		margin: 0 0 1rem 0;
	}

	.policy-clause p {
		color: #aaaaaa;
		font-size: 0.98rem;
		line-height: 1.7;
		margin: 0 0 1rem 0;
	}

	.policy-clause ul {
		color: #aaaaaa;
		font-size: 0.98rem;
		line-height: 1.7;
		margin: 0;
		padding-left: 1.5rem;
	}

	.policy-clause li {
		margin-bottom: 0.5rem;
	}

	@media (max-width: 768px) {
		.policy-container {
			padding: 7rem 5% 4rem 5%;
		}
		
		.policy-hero h1 {
			font-size: 2.5rem;
		}

		.policy-content {
			padding: 2rem 1.5rem;
			min-height: auto;
		}
	}
</style>
