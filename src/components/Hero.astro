---
import movies from '../data/movies.json';
import { slugify } from '../utils/slugify.js';

const featuredMovie = movies.find(m => m.isFeatured) || movies[0];
---

<section class="hero">
	<div class="hero-bg">
		<img 
			src={featuredMovie.imageUrl} 
			alt={`${featuredMovie.title} Background`} 
			fetchpriority="high" 
			loading="eager" 
			onload="this.classList.add('loaded'); this.parentElement.classList.add('loaded');"
		/>
		<div class="overlay"></div>
	</div>
	<div class="hero-content">
		<span class="badge">Trending Now</span>
		<h2 class="title">{featuredMovie.title}</h2>
		<p class="description">
			{featuredMovie.description}
		</p>
		<div class="actions">
			<a href={`/movie/${slugify(featuredMovie.title)}`} class="btn btn-primary">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M8 5V19L19 12L8 5Z" fill="currentColor"/>
				</svg>
				Play Trailer
			</a>
			<a href={`/movie/${slugify(featuredMovie.title)}`} class="btn btn-secondary">More Info</a>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		height: 80vh;
		min-height: 600px;
		max-height: 720px;
		display: flex;
		align-items: center;
		padding: 0 5%;
		margin-bottom: 3rem;
	}

	.hero-bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 1;
		background-color: #0c0c0c;
		background-image: linear-gradient(
			90deg,
			rgba(255, 255, 255, 0.01) 25%,
			rgba(255, 255, 255, 0.04) 50%,
			rgba(255, 255, 255, 0.01) 75%
		);
		background-size: 200% 100%;
		animation: loading-pulse 2s infinite;
	}

	.hero-bg.loaded {
		animation: none;
		background: none;
	}

	.hero-bg img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 20%;
		opacity: 0;
		transition: opacity 0.6s ease-in-out;
	}

	.hero-bg img.loaded {
		opacity: 1;
	}

	@keyframes loading-pulse {
		0% {
			background-position: 200% 0;
		}
		100% {
			background-position: -200% 0;
		}
	}

	.overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0) 100%),
					linear-gradient(to top, rgba(0,0,0,1) 0%, transparent 20%);
	}

	.hero-content {
		max-width: 600px;
		z-index: 10;
		margin-top: 5rem;
	}

	.badge {
		background-color: rgba(229, 9, 20, 0.2);
		color: var(--accent-color);
		padding: 0.3rem 0.8rem;
		border-radius: 4px;
		font-size: 0.8rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 1px;
		display: inline-block;
		margin-bottom: 1rem;
		border: 1px solid rgba(229, 9, 20, 0.4);
	}

	.title {
		font-size: 4rem;
		font-weight: 800;
		margin: 0 0 1rem 0;
		line-height: 1.1;
		letter-spacing: -1px;
	}

	.description {
		font-size: 1.1rem;
		line-height: 1.6;
		color: #ffffff;
		margin-bottom: 2rem;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.actions {
		display: flex;
		gap: 1rem;
	}

	.btn {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.8rem 1.5rem;
		border: none;
		border-radius: 4px;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.3s ease;
		text-decoration: none;
		text-shadow: none;
		box-shadow: none;
	}

	.btn-primary {
		background-color: var(--text-color);
		color: var(--bg-color);
	}

	.btn-primary:hover {
		background-color: rgba(255, 255, 255, 0.8);
		transform: scale(1.05);
	}

	.btn-secondary {
		background-color: rgba(255, 255, 255, 0.2);
		color: var(--text-color);
		backdrop-filter: blur(5px);
	}

	.btn-secondary:hover {
		background-color: rgba(255, 255, 255, 0.3);
	}

	@media (max-width: 768px) {
		.title {
			font-size: 2.5rem;
		}
		.hero-content {
			margin-top: 2rem;
		}
	}
</style>
