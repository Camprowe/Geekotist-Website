---
interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
	type?: string;
	movieData?: {
		title: string;
		description: string;
		imageUrl: string;
		year: string;
		rating: string;
		category: string;
	};
}

const {
	title = "SR Studio Antigravity Movies - Discover Finest Cinematic Masterpieces",
	description = "Your ultimate destination for the finest cinematic masterpieces. Browse, search, and discover timeless classics across multiple genres.",
	image = "https://image.tmdb.org/t/p/original/8cdWjvZQUExUUTzyp4t6EDMubfO.jpg", // Default featured movie backdrop
	canonicalURL = Astro.url.href,
	type = "website",
	movieData
} = Astro.props;

// Structured Data (JSON-LD)
const baseSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "SR Studio Antigravity Movies",
	"url": "https://antigravity-movies.com",
	"potentialAction": {
		"@type": "SearchAction",
		"target": "https://antigravity-movies.com/?search={search_term_string}",
		"query-input": "required name=search_term_string"
	}
};

const movieSchema = movieData ? {
	"@context": "https://schema.org",
	"@type": "Movie",
	"name": movieData.title,
	"description": movieData.description,
	"image": movieData.imageUrl,
	"dateCreated": movieData.year,
	"aggregateRating": {
		"@type": "AggregateRating",
		"ratingValue": movieData.rating,
		"bestRating": "10",
		"worstRating": "1",
		"ratingCount": "100"
	},
	"genre": movieData.category
} : null;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:site_name" content="SR Studio Antigravity Movies" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />

		<!-- Preconnect Links -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />
		{movieSchema && (
			<script type="application/ld+json" set:html={JSON.stringify(movieSchema)} />
		)}
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #000000;
		--text-color: #ffffff;
		--text-muted: #ffffff;
		--accent-color: #e50914; /* Cinematic red */
	}

	*, *::before, *::after {
		box-sizing: border-box;
	}

	html {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100vh;
		background-color: #080808; /* Cinematic dark ambient frame background for extra-wide displays */
	}

	body {
		margin: 0 auto;
		padding: 0;
		width: 100%;
		max-width: 1440px;
		min-height: 100vh;
		background-color: var(--bg-color);
		color: var(--text-color);
		font-family: 'Inter', sans-serif;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
		overflow-x: hidden;
		text-shadow: 2px 2px 4px #000000;
		box-shadow: 0 0 80px rgba(0, 0, 0, 0.95);
		border-left: 1px solid rgba(255, 255, 255, 0.03);
		border-right: 1px solid rgba(255, 255, 255, 0.03);
		position: relative;
	}
	
	a {
		color: inherit;
		text-decoration: none;
	}
</style>
