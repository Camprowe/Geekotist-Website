---
import { slugify } from '../utils/slugify.js';

interface Props {
	title: string;
	imageUrl: string;
	category: string;
	year: string;
	producer: string;
}

const { title, imageUrl, year, producer, category } = Astro.props;
const slug = slugify(title);

const truncatedTitle = title.length > 30 ? title.slice(0, 30) + "..." : title;
---

<section class="card">
  <a class="game-card" href={`/entertainment/${slug}`} aria-label={`View game page: ${title}`}>
    <div class="poster">
      <div class="link-arrow">
        <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 9L9 3M9 3H4.5M9 3V7.5" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
 
    <div class="info">
      <h3 class="title">{truncatedTitle}</h3>
      <div class="meta">
        <div class="meta-row">
          <span class="meta-label">STUDIO</span>
          <span class="meta-value">{producer}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label">RELEASED</span>
          <span class="meta-value">{year}</span>
        </div>
      </div>
    </div>
  </a>
</section>

<style define:vars={{image: `url("${imageUrl}")`}}>

	:root{
    --ink: #17181A;
    --ink-raised: #1D1F21;
    --paper: #EDE6D8;
    --paper-dim: #B9B2A4;
    --brass: #FFA500;
    --spotlight: #E8B458;
    --hairline: rgba(237,230,216,0.50);
  }

	.card {
		margin: 0;
		min-height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	 .game-card{
    display: block;
    width: 100%;
    text-decoration: none;
    background: var(--ink);
    border-radius: 6px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(237,230,216,0.06) inset,
      0 24px 48px -20px rgba(0,0,0,0.6);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
 
  .game-card:hover{
    transform: translateY(-3px);
    box-shadow:
      0 1px 0 rgba(237,230,216,0.08) inset,
      0 30px 56px -18px rgba(0,0,0,0.7);
  }
 
  .game-card:focus-visible{
    outline: 2px solid var(--brass);
    outline-offset: 3px;
  }
 
  /* ---------- poster art (9:16) ---------- */
  .poster{
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(232,180,88,0.14), transparent 60%),
      linear-gradient(180deg, #24262A 0%, #1A1B1D 100%);
	background-image: var(--image);
	background-size: cover;
	background-position: center;
    border-bottom: 1px solid var(--hairline);
    overflow: hidden;
  }
 
  .link-arrow{
    position: absolute;
    bottom: 8px;
    right: 8px;
    width: 22px; height: 22px;
    border-radius: 50%;
    background: rgba(0,0,0,0.55);
    border: 1px solid rgba(237,230,216,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
 
  .game-card:hover .link-arrow{
    background: var(--brass);
    border-color: var(--brass);
  }
 
  .link-arrow svg{
    width: 10px; height: 10px;
    stroke: var(--paper);
  }
 
  /* ---------- details ---------- */
  .info{
    padding: 13px 15px 15px;
  }
 
  .title{
    font-weight: 900;
    font-size: 15px;
    line-height: 1.3;
    color: var(--paper);
    margin: 0 0 8px;
  }
 
  .meta{
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
 
  .meta-row{
    display: flex;
    align-items: baseline;
    gap: 6px;
    font-size: 11.5px;
  }
 
  .meta-label{
    font-size: 9.5px;
    letter-spacing: 0.06em;
    color: var(--brass);
    width: 52px;
    flex-shrink: 0;
  }
 
  .meta-value{
    color: var(--paper-dim);
  }
</style>
